# Supabase — copy to .env.local and fill in from your Supabase project settings.
# Project Settings -> API

# Public (safe to ship to the browser; RLS protects the data)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. NEVER prefix with NEXT_PUBLIC_ and never ship to the browser.
# Bypasses RLS — used for registration, Super Admin, and background jobs.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
